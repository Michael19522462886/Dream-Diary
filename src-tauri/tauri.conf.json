{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dream Diary",
  "version": "0.1.0",
  "identifier": "com.codex.dreamdiary",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Dream Diary",
        "width": 1560,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 820,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"]
  }
}
